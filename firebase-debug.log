[debug] [2026-07-15T23:17:05.029Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/go-influence/rulesets {"name":"projects/go-influence/rulesets/e49551e1-f09f-488f-9545-8c08907ff28f","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    function userDoc() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    function isAdmin() {\n      return signedIn() && userDoc().data.role == 'admin';\n    }\n\n    function isBrand() {\n      return signedIn() && userDoc().data.role == 'brand';\n    }\n\n    function isInfluencer() {\n      return signedIn() && userDoc().data.role == 'influencer';\n    }\n\n    match /users/{uid} {\n      allow read: if isOwner(uid) || isAdmin();\n      allow create: if isOwner(uid) || isAdmin();\n      allow update: if isOwner(uid) || isAdmin();\n    }\n\n    match /brands/{uid} {\n      allow read: if signedIn();\n      allow create, update: if isOwner(uid) || isAdmin();\n    }\n\n    match /influencers/{uid} {\n      allow read: if signedIn();\n      allow create, update: if isOwner(uid) || isAdmin();\n    }\n\n    match /campaigns/{campaignId} {\n      allow read: if signedIn();\n      allow create: if isAdmin()\n        || (isBrand() && request.resource.data.brandUid == request.auth.uid);\n      allow update, delete: if isAdmin()\n        || (isBrand() && resource.data.brandUid == request.auth.uid);\n    }\n\n    match /campaignOffers/{offerId} {\n      allow create: if (\n          isInfluencer()\n          && request.resource.data.creatorId == request.auth.uid\n          && (!('influencerUid' in request.resource.data) || request.resource.data.influencerUid == request.auth.uid)\n        ) || (\n          isBrand()\n          && request.resource.data.brandUid == request.auth.uid\n          && request.resource.data.creatorId is string\n          && request.resource.data.creatorId.size() > 0\n          && (!('influencerUid' in request.resource.data) || request.resource.data.influencerUid == request.resource.data.creatorId)\n        );\n      allow read: if isAdmin()\n        || resource.data.brandUid == request.auth.uid\n        || resource.data.creatorId == request.auth.uid\n        || resource.data.influencerUid == request.auth.uid;\n      allow update: if isAdmin()\n        || resource.data.brandUid == request.auth.uid\n        || resource.data.creatorId == request.auth.uid\n        || resource.data.influencerUid == request.auth.uid;\n    }\n\n    match /campaignMatches/{matchId} {\n      allow create, update: if isAdmin()\n        || (isBrand() && request.resource.data.brandUid == request.auth.uid);\n      allow read: if isAdmin()\n        || resource.data.brandUid == request.auth.uid\n        || resource.data.influencerUid == request.auth.uid;\n      allow delete: if isAdmin()\n        || (isBrand() && resource.data.brandUid == request.auth.uid);\n    }\n\n    match /chatThreads/{threadId} {\n      allow create: if signedIn()\n        && request.auth.uid in request.resource.data.participants;\n      allow read, update: if signedIn()\n        && request.auth.uid in resource.data.participants;\n    }\n\n    match /settings/{settingId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /transactions/{transactionId} {\n      allow read: if isAdmin()\n        || resource.data.brandUid == request.auth.uid\n        || resource.data.influencerUid == request.auth.uid;\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-15T23:17:01.267583Z","metadata":{"services":["cloud.firestore"]}}
